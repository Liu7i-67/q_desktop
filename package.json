{
  "name": "q_desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/app/main.js",
  "description": "electron study by liu7i",
  "author": "liu7i",
  "scripts": {
    "build:web": "rsbuild build",
    "dev": "npm-run-all --parallel dev:web dev:electron",
    "dev:web": "rsbuild dev",
    "dev:electron": "npm run translate:electron && cross-env NODE_ENV=development electron .",
    "format": "prettier --write .",
    "preview:web": "rsbuild preview",
    "translate:electron": "tsc --project src/app/tsconfig.json",
    "package:mac": "npm run translate:electron && npm run build:web && electron-builder --mac --arm64",
    "package:win": "npm run translate:electron && npm run build:web && electron-builder --win --x64",
    "package:linux": "npm run translate:electron && npm run build:web && electron-builder --linux --x64"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@ant-design/icons": "^5.5.2",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@quarkunlimit/qu-mobx": "^1.0.0",
    "antd": "^5.23.0",
    "axios": "^1.7.9",
    "big.js": "^6.2.2",
    "copy-to-clipboard": "^3.3.3",
    "dayjs": "^1.11.13",
    "echarts": "^5.6.0",
    "lodash": "^4.17.21",
    "react-fast-marquee": "^1.6.5",
    "react-router": "^7.1.1",
    "uuid": "^11.0.4"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.2.16",
    "@rsbuild/plugin-react": "^1.1.1",
    "@types/node": "^22.13.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "electron": "^35.0.3",
    "electron-builder": "^25.1.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.2",
    "typescript": "^5.8.2",
    "@quarkunlimit/immer": "latest",
    "@quarkunlimit/react-hooks": "latest",
    "@quarkunlimit/tiny": "latest",
    "@rspack/cli": "^1.1.8",
    "@rspack/core": "^1.1.8",
    "@rspack/plugin-react-refresh": "1.0.0",
    "@types/lodash": "^4.17.16",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "postcss-antd-fixes": "^0.2.0",
    "react-refresh": "^0.14.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "@types/big.js": "^6.2.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "electron"
    ]
  }
}
